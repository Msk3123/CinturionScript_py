# ================================================================
#  .env.example — скопіюй у .env і заповни своїми значеннями
#
#  cp .env.example .env   (Linux/Mac)
#  copy .env.example .env (Windows)
# ================================================================

# ---------------------------------------------------------------
# ОБОВ'ЯЗКОВО — без цього бот не запуститься
# ---------------------------------------------------------------

# Токен Telegram-бота (отримай у @BotFather → /newbot)
TG_BOT_TOKEN=1234567890:ABCDefGhIJKlmNoPQRsTUVwxyZ

# ---------------------------------------------------------------
# ОПЦІЙНО — є дефолтні значення, можна не вказувати
# ---------------------------------------------------------------

# URL YouTube-плейлиста для генерації міксу
# Можна також задати прямо через бота (кнопка ⚙️ Налаштування)
PLAYLIST_URL=https://www.youtube.com/playlist?list=XXXXXXXXXXXXXXXXXXXXXXXX

# Шлях до beep.mp3 (відносно кореня проєкту)
BEEP_PATH=assets/beep.mp3

# Тимчасова папка для завантажених треків
TEMP_DIR=data/temp

# Шлях до фінального мікс-файлу
OUTPUT_PATH=data/output/Centurion_Mix_BEST.mp3

# Папка з ffmpeg-бінарниками (для Windows; на Linux ігнорується — береться з PATH)
FFMPEG_DIR=ffmpeg

# Бітрейт кодування фінального mp3 (64k / 128k / 192k / 320k)
BITRATE=192k

# Тривалість одного фрагменту треку у секундах
DURATION_SEC=60

# Корекція гучності beep-сигналу в дБ (від'ємне = тихіше)
BEEP_GAIN_DB=-10

# Рівень логування: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
