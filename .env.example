# ============================================================
# .env.example — скопіюй у .env і заповни своїми значеннями
# НІКОЛИ не комітай .env у git!
# ============================================================

# --- ОБОВ'ЯЗКОВО ---
TG_BOT_TOKEN=1234567890:AABBccDDeeFFggHHiiJJkkLLmmNNooP

# --- YouTube плейлист ---
PLAYLIST_URL=https://www.youtube.com/playlist?list=PLxxxxxxxxxxxxxxxxxx

# --- Шляхи (можна залишити за замовчуванням) ---
BEEP_PATH=assets/beep.mp3
TEMP_DIR=data/temp
OUTPUT_PATH=data/output/Centurion_Mix.mp3

# --- Аудіо налаштування ---
BITRATE=192k
DURATION_SEC=60
BEEP_GAIN_DB=-10

# --- Логування: DEBUG / INFO / WARNING / ERROR ---
LOG_LEVEL=INFO

